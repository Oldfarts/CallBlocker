<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/colorBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="horizontal"
            android:background="@color/colorPrimary"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="CallBlocker"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:text="Puhelunestopalvelu"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            style="@style/CallBlocker.Card"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/titleCallScreening"
                style="@style/CallBlocker.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Puhelunestopalvelu" />

            <TextView
                style="@style/CallBlocker.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ota puhelunestopalvelu käyttöön, jotta estot toimivat taustalla OnePlus Nord CE 3 Litessä." />

            <Switch
                android:id="@+id/switchCallScreening"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Puhelunestopalvelu käytössä" />
        </LinearLayout>

        <LinearLayout
            style="@style/CallBlocker.Card"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/titleForeign"
                style="@style/CallBlocker.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ulkomaiset puhelut" />

            <TextView
                style="@style/CallBlocker.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estä kaikki ulkomaiset puhelut. Suomi (+358) sallitaan aina." />

            <Switch
                android:id="@+id/switchBlockForeign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estä ulkomaiset puhelut" />

            <Button
                android:id="@+id/allowedCountriesBtn"
                style="@style/CallBlocker.Button.Neutral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sallitut maatunnukset (poikkeukset)" />
        </LinearLayout>

        <LinearLayout
            style="@style/CallBlocker.Card"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/titleSpam"
                style="@style/CallBlocker.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Häirikkösoittajat" />

            <TextView
                style="@style/CallBlocker.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Androidin tunnistamat 'Mahdollinen häirikkösoittaja' -puhelut voidaan estää automaattisesti." />

            <Switch
                android:id="@+id/switchBlockSpam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estä häirikkösoittajat" />
        </LinearLayout>

        <LinearLayout
            style="@style/CallBlocker.Card"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                style="@style/CallBlocker.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Numerolistat" />

            <Button
                android:id="@+id/allowedNumbersBtn"
                style="@style/CallBlocker.Button.Neutral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sallitut numerot (poikkeukset)" />

            <Button
                android:id="@+id/blockedNumbersBtn"
                style="@style/CallBlocker.Button.Danger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kielletyt numerot" />
        </LinearLayout>

        <LinearLayout
            style="@style/CallBlocker.Card"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                style="@style/CallBlocker.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lokit ja raportit" />

            <Button
                android:id="@+id/logBtn"
                style="@style/CallBlocker.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Näytä estoloki" />

            <Button
                android:id="@+id/spamBtn"
                style="@style/CallBlocker.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Näytä spam-raportti" />
        </LinearLayout>

        <!-- 🔥 saveBtn POISTETTU TÄSTÄ ALAPUOLELTA -->

    </LinearLayout>
</ScrollView>