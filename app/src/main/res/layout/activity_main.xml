<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Ulkomaiset puhelut -->
<TextView
    android:text="Puhelunestopalvelu käytössä"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" />

<Switch
    android:id="@+id/switchCallScreening"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" />

        <TextView
            android:text="Estä ulkomaiset puhelut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Switch
            android:id="@+id/switchBlockForeign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Spam-soittajat -->
        <TextView
            android:text="Estä häirikkösoittajat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Switch
            android:id="@+id/switchBlockSpam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Poikkeukset (sallitut numerot) -->
        <Button
            android:id="@+id/allowedNumbersBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sallitut numerot (poikkeukset)"
            android:padding="10dp" />

        <!-- Kielletyt numerot -->
        <Button
            android:id="@+id/blockedNumbersBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kielletyt numerot"
            android:padding="10dp" />

        <!-- Kielletyt maatunnukset -->
        <Button
            android:id="@+id/blockedCountriesBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kielletyt maatunnukset"
            android:padding="10dp" />

        <!-- Tallennus -->
        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tallenna asetukset" />

        <!-- Roolin aktivointi 
        <Button
            android:id="@+id/roleBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ota puhelunestopalvelu käyttöön" />-->

        <!-- Lokit -->
        <Button
            android:id="@+id/logBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Näytä estoloki" />

        <Button
            android:id="@+id/spamBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Näytä spam-raportti" />

    </LinearLayout>
</ScrollView>
