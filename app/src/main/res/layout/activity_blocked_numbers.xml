<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        style="@style/CallBlocker.SectionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kielletyt numerot" />

    <TextView
        style="@style/CallBlocker.Label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nämä numerot estetään aina." />

    <EditText
        android:id="@+id/blockedNumberInput"
        android:hint="+358401234567"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/addBlockedNumberBtn"
        style="@style/CallBlocker.Button.Danger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lisää kielletty numero" />

    <Button
        android:id="@+id/removeBlockedNumberBtn"
        style="@style/CallBlocker.Button.Neutral"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Poista kielletty numero" />

    <ListView
        android:id="@+id/blockedNumbersList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/backBtn"
        style="@style/CallBlocker.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Palaa takaisin" />
</LinearLayout>
